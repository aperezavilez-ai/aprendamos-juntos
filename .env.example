# ============================================================
# TerapiaOS — Variables de entorno
# Copia este archivo como .env.local en apps/web/
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Obtén estos valores en https://app.supabase.com/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic Claude API ─────────────────────────────────────
# Obtén tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── WhatsApp Business API (Meta) ─────────────────────────────
# Configura en https://developers.facebook.com/apps/
# 1. Crea una app de tipo Business
# 2. Agrega el producto "WhatsApp"
# 3. Genera un Access Token permanente
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu-token-secreto-para-verificar-webhook

# ── Seguridad ────────────────────────────────────────────────
# Token para proteger el endpoint de recordatorios (cron job)
# Genera uno aleatorio: openssl rand -hex 32
CRON_SECRET=tu-token-secreto-para-cron

# ── Opcional: URL base de la app ─────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Opcional: Storage (si usas Supabase Storage) ─────────────
NEXT_PUBLIC_STORAGE_BUCKET=terapia-os-files
